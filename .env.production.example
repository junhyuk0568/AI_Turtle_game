OPENAI_API_KEY=
OPENAI_CLASSIFIER_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2
OPENAI_REASONING_EFFORT=low
OPENAI_QUESTION_MAX_OUTPUT_TOKENS=1000
OPENAI_FINAL_ANSWER_MAX_OUTPUT_TOKENS=1000
OPENAI_CRITERIA_MAX_OUTPUT_TOKENS=5000

DJANGO_SECRET_KEY=replace-this-with-a-long-random-production-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
GAME_LOG_LEVEL=INFO
